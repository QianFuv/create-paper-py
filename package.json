{
  "name": "@qianfuv/create-paper-py",
  "version": "1.0.0",
  "description": "Scaffold a UV-powered Python research paper project in seconds",
  "type": "module",
  "bin": "dist/index.js",
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "smoke": "npm run build && node dist/smoke.js",
    "lint": "eslint src",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "python",
    "uv",
    "scaffold",
    "paper",
    "research",
    "template",
    "create-paper-py"
  ],
  "homepage": "https://github.com/QianFuv/create-paper-py#readme",
  "bugs": {
    "url": "https://github.com/QianFuv/create-paper-py/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QianFuv/create-paper-py.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "gradient-string": "^3.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1"
  }
}
